{
  "manifest_version": 3,
  "name": "AI/Gemini Folders — Selector Diagnostics",
  "version": "1.0",
  "description": "Maintainer tool: opens each supported AI site and checks whether its editor selectors still match, flagging when only the positional fallback works.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://chatgpt.com/*",
    "*://copilot.microsoft.com/*",
    "*://chat.deepseek.com/*",
    "*://grok.com/*",
    "*://*.grok.com/*",
    "*://perplexity.ai/*",
    "*://*.perplexity.ai/*",
    "*://chat.z.ai/*",
    "*://chat.qwen.ai/*",
    "*://meta.ai/*",
    "*://*.meta.ai/*",
    "*://chat.mistral.ai/*",
    "*://poe.com/*",
    "*://*.poe.com/*",
    "*://duck.ai/*",
    "*://duckduckgo.com/*",
    "*://you.com/*",
    "*://*.you.com/*",
    "*://pi.ai/*",
    "*://*.pi.ai/*",
    "*://character.ai/*",
    "*://*.character.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Folders selector diagnostics"
  }
}
